{
  "name": "dateright-management",
  "version": "0.1.0",
  "private": true,
  "description": "DateRight content management system (Payload CMS + MongoDB) and matching agent.",
  "main": "src/server.ts",
  "scripts": {
    "dev": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts nodemon",
    "serve": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts ts-node src/server.ts",
    "seed": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts ts-node src/seed.ts",
    "build": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload build",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:types"
  },
  "dependencies": {
    "@payloadcms/bundler-webpack": "1.0.9",
    "@payloadcms/db-mongodb": "1.7.5",
    "@payloadcms/richtext-slate": "1.5.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "payload": "^2.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
